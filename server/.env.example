NODE_ENV=development
PORT=5001
CORS_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=myPanda@20030711
DB_NAME=ecommerce_db
DB_SSL=false
DB_INIT_ON_START=false
DEBUG_SQL=false

JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=30d

# IMS integration
IMS_API_URL=http://localhost:5000
IMS_API_KEY=
IMS_AUTH_HEADER=Authorization
IMS_AUTH_PREFIX=Bearer
IMS_PRODUCTS_PATH=/api/products
IMS_STOCK_PATH=/api/products/:id/stock
# Optional batch endpoint. If empty, stock is fetched product-by-product.
IMS_STOCKS_PATH=
# Set true only if your IMS sales endpoint should deduct/reserve stock on checkout.
IMS_SYNC_SALES_ON_ORDER=false
IMS_SALES_PATH=/api/sales
# Set false to allow checkout when IMS stock endpoint is unavailable.
IMS_ENFORCE_STOCK=true
